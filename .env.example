# Copy this file to .env and fill in your own values

# Your MongoDB connection string (MongoDB Atlas or local)
MONGO_URI=mongodb://127.0.0.1:27017/vibely

# Any long random string, used to sign login tokens
JWT_SECRET=change_this_to_a_long_random_secret

# Port the backend server runs on
PORT=5000

# URL of the frontend (used for CORS)
CLIENT_URL=http://localhost:3000

# ---- Email (used for OTP: signup verification, password reset, phone-verify fallback) ----
# Any SMTP provider works (Gmail App Password, Brevo, Zoho, SendGrid SMTP, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Vibely <no-reply@vibely.app>"

# ---- SMS (optional, not configured yet) ----
# Leave blank for now. When you get Twilio/MSG91 keys, add them here and
# flip PHONE_OTP_PROVIDER to "twilio" or "msg91" in backend/utils/sms.js
SMS_PROVIDER=none

# ---- Cloudinary (image/video storage for posts, reels, stories, avatars) ----
# Free account: https://cloudinary.com/users/register/free
# Find these on your Cloudinary Dashboard homepage after signing up
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
